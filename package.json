{
  "name": "garnish",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm run start -w @garnish/mobile",
    "mobile:android": "npm run android -w @garnish/mobile",
    "mobile:ios": "npm run ios -w @garnish/mobile",
    "api": "npm run dev -w @garnish/api",
    "api:build": "npm run build -w @garnish/api",
    "shared:build": "npm run build -w @garnish/shared",
    "db:generate": "npm run db:generate -w @garnish/api",
    "db:push": "npm run db:push -w @garnish/api",
    "db:studio": "npm run db:studio -w @garnish/api",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "clean": "turbo run clean"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
